# ========================================
# Banho & Tosa API - Configurações .env
# ========================================
#
# Local Development (start.bat): Use SQLite
# Docker Compose: Uncomment PostgreSQL line below
#

# Local Dev - SQLite (recommended for development)
DATABASE_URL=sqlite:///./banho_tosa.db

# Docker Prod/Full Stack - PostgreSQL
# DATABASE_URL=postgresql://postgres:Alessandra22@db:5432/pacotesbanho

# Other settings
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

